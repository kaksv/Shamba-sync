# =============================================================================
# Shamba-Sync Environment Configuration
# =============================================================================

# Server
PORT=3001
NODE_ENV=development

# OpenAI / LLM API (for production voice transcription, vision analysis, and translation)
OPENAI_API_KEY=sk-your-openai-api-key-here
OPENAI_MODEL=gpt-4o

# Twilio (WhatsApp integration - for production WhatsApp usage)
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_WHATSAPP_NUMBER=+14155238886

# CROO Agent Protocol (CAP) - On-chain settlement
# CAP_AGENT_ID: You choose this yourself. Make it unique to your agent.
#   Format: your-agent-name-v1 (e.g. shamba-sync-v1, my-cool-agent-v2)
#   Convention: lowercase, hyphens for spaces, version suffix
CAP_AGENT_ID=shamba-sync-v1

# CAP_REGISTRY_URL: CROO's API endpoint where agents register.
#   For hackathon/demo: https://api.croo.io/v1/cap
#   In production (when live): the official URL CROO provides in their docs
#   This tells the agent where to register itself on the CROO network
CAP_REGISTRY_URL=https://api.croo.io/v1/cap

# USDC_WALLET_ADDRESS: Your Solana wallet public key to receive payments.
#   Get this from Phantom, Solflare, or any Solana wallet
#   Format: Base58 string (e.g. 9cE6uKBovLwS7fmBJY9B1kjAnidyKSCmUFyv1TV4L8Dw)
USDC_WALLET_ADDRESS=your-solana-wallet-public-key-for-receiving-usdc

# Redis (optional - for caching market data)
REDIS_URL=

# Logging
LOG_LEVEL=info