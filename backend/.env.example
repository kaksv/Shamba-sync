# =============================================================================
# Shamba-Sync Environment Configuration
# =============================================================================

# Server
PORT=3001
NODE_ENV=development

# OpenAI / LLM API (for production voice transcription, vision analysis, and translation)
OPENAI_API_KEY=sk-your-openai-api-key-here
OPENAI_MODEL=gpt-4o

# Twilio (WhatsApp integration - for production WhatsApp usage)
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_WHATSAPP_NUMBER=+14155238886

# CROO Agent Protocol (CAP) - On-chain settlement
CAP_AGENT_ID=shamba-sync-v1
CAP_REGISTRY_URL=https://api.croo.io/v1/cap
USDC_WALLET_ADDRESS=your-solana-wallet-public-key-for-receiving-usdc

# Redis (optional - for caching market data)
REDIS_URL=

# Logging
LOG_LEVEL=info